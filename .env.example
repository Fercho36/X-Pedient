# ==========================================
# Archivo de Ejemplo de Variables de Entorno
# ==========================================
# Renombra este archivo a ".env" y reemplaza 
# los valores con tus propias credenciales.

# Contraseña de aplicación de Gmail para el envío de correos
GMAIL_APP_PASSWORD=tu_contraseña_de_aplicacion_gmail

# Clave de la API de API2PDF para la generación de documentos
API2PDF_KEY=tu_api_key_de_api2pdf

# Llave de encriptación maestra (Generada con generate_key.py)
# FERNET_KEY=tu_llave_generada_aqui
